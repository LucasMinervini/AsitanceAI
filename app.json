{
  "expo": {
    "name": "Mobile AI Assistance",
    "slug": "mobile-ai-assistance",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Permití el acceso al micrófono para dictar tus mensajes por voz."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permití el acceso a la cámara para enviar fotos al asistente."
        }
      ]
    ]
  }
}
