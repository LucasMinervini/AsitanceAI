# Plantilla de variables de entorno. Copiar a .env y rellenar.
# .env NUNCA se versiona (ver .gitignore). Solo infrastructure/config/env.ts lo lee.
# En el runtime de Expo se leen las mismas claves con prefijo EXPO_PUBLIC_ (ver expoEnvSource()).

# Proveedor de IA: "ollama" (local, sin auth) | "huggingface" (requiere API key).
AI_AGENT_PROVIDER=ollama

# Endpoint del agente IA.
#   ollama:      http://localhost:11434/api
#   huggingface: https://router.huggingface.co/v1
AI_AGENT_BASE_URL=

# Clave del agente. Requerida si AI_AGENT_PROVIDER=huggingface; vacía para Ollama local.
AI_AGENT_API_KEY=

# Modelo por defecto.
#   ollama:      llama3.2, mistral, qwen2.5, ...
#   huggingface: meta-llama/Llama-3.1-8B-Instruct, google/gemma-3-12b-it, ...
AI_AGENT_MODEL=

# ── Transcripción de voz (Whisper, siempre vía HuggingFace) ──────────────
# Los defaults ya apuntan al router de HF; sobreescribir solo si hace falta.
AI_STT_BASE_URL=https://router.huggingface.co/hf-inference/models
AI_STT_MODEL=openai/whisper-large-v3
# Si se deja vacía, cae al token del agente (AI_AGENT_API_KEY).
AI_STT_API_KEY=
