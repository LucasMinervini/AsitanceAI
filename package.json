{
  "name": "mobile-ai-assistance",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "description": "App Mobile de Asistencia IA - Clean Architecture + TDD",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "start": "expo start --clear",
    "tunnel": "expo start --tunnel --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:domain": "vitest run tests/domain",
    "test:application": "vitest run tests/application",
    "test:contracts": "vitest run tests/contracts",
    "test:infrastructure": "vitest run tests/infrastructure",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.17",
    "@vitest/coverage-v8": "^2.1.0",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.12.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/elements": "^2.9.26",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "expo": "^54.0.35",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-web": "^0.21.2",
    "zod": "^3.23.0"
  }
}
